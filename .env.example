cat > .env.example <<'EOF'
NIGHTSCOUT_URL=https://your-nightscout-site.example.com
NIGHTSCOUT_TOKEN=

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_sender_gmail@gmail.com
EMAIL_APP_PASSWORD=your_google_app_password

JULIE_EMAIL=recipient@example.com
PARENT_EMAIL=parent@example.com

DRY_RUN=true
TIMEZONE=America/New_York

POD_INITIAL_UNITS=200
POD_RECORD_STALE_HOURS=84
DEXCOM_RECORD_STALE_HOURS=264

LOW_NOW=70
LOW_SOON_30_MIN=75
LOW_SOON_60_MIN=70

HIGH_NOW=250
HIGH_PREDICTED=220
STALE_MINUTES=15

POD_WARN_HOURS=68
POD_EXPIRE_HOURS=72

DEXCOM_WARN_HOURS=234
DEXCOM_REPLACE_HOURS=240
DEXCOM_URGENT_HOURS=250

POD_INSULIN_WARN_U=10
POD_INSULIN_URGENT_U=5
EOF
